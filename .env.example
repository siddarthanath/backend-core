# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=backend-core
APP_VERSION=0.1.0
DEBUG=false
# JSON array of allowed CORS origins
CORS_ORIGINS=["http://localhost:3000"]
# Base URL of the frontend — used to build absolute links in transactional emails
FRONTEND_BASE_URL=http://localhost:3000
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_DEFAULT=60/minute

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL — change only this URL to swap databases
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ── Auth (Supabase JWT) ───────────────────────────────────────────────────────
# Backend decodes tokens only — never creates them
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_JWT_SECRET=[YOUR_JWT_SECRET]
SUPABASE_ANON_KEY=[YOUR_ANON_KEY]
# Service role key — server-side only, never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]

# ── External ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_MAX_MONTHLY_PRICE_ID=
STRIPE_MAX_YEARLY_PRICE_ID=
RESEND_API_KEY=